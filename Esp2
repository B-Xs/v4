--// Glow Chams 
local InstanceNew = Instance.new
local CFrameNew  = CFrame.new
local Vec3       = Vector3.new

local function RemoveAdorns(Part)
    if not Part then return end
    for _, Obj in ipairs(Part:GetChildren()) do
        if Obj.Name == "Chams" or Obj.Name == "Glow" then
            Obj:Destroy()
        end
    end
end

local function CreateAdornment(Part, Type, Color, Trans, ZIndex, SizeOffset, Extra)
    Extra = Extra or {}
    local Ad
    if Type == "Cylinder" then
        Ad = InstanceNew("CylinderHandleAdornment")
        Ad.Height  = Part.Size.Y + (Extra.HeightOffset or 0)
        Ad.Radius  = (Part.Size.X * 0.5) + (Extra.RadiusOffset or 0)
        Ad.CFrame  = CFrameNew(Vec3(), Vec3(0,1,0))
    elseif Type == "Box" then
        Ad = InstanceNew("BoxHandleAdornment")
        Ad.Size = Part.Size + (SizeOffset or Vec3.zero)
    end
    Ad.Name         = "Chams"
    Ad.AlwaysOnTop  = true
    Ad.ZIndex       = ZIndex
    Ad.Adornee      = Part
    Ad.Color3       = Color
    Ad.Transparency = Trans or 0
    if Extra.Shading then Ad.Shading = Extra.Shading end
    Ad.Parent = Part
    return Ad
end

function y:ClearGlowChams()
    for _, adorn in ipairs(self.GlowChams) do
        if adorn and adorn.Parent then
            adorn:Destroy()
        end
    end
    table.clear(self.GlowChams)
end

function y:UpdateGlowChams(color)
    self:ClearGlowChams()
    if not a.GlowChamsEnabled then return end

    local Char = self.Player.Character
    if not Char then return end

    for _, Part in ipairs(Char:GetChildren()) do
        if not Part:IsA("BasePart") or Part.Transparency >= 1 then continue end
        RemoveAdorns(Part)

        local IsHead = Part.Name == "Head" or Part.Name == "FakeHead"

   
        local Glow = CreateAdornment(
            Part,
            IsHead and "Cylinder" or "Box",
            Color3.new(color.R * a.GlowMultiplier, color.G * a.GlowMultiplier, color.B * a.GlowMultiplier),
            -1,
            IsHead and 10 or 9,
            a.GlowSizeOffset,
            {Shading = Enum.AdornShading.XRayShaded}
        )
        table.insert(self.GlowChams, Glow)


        local Main = CreateAdornment(
            Part,
            IsHead and "Cylinder" or "Box",
            color,
            a.GlowTransparency,
            10,
            a.GlowSizeOffset
        )
        table.insert(self.GlowChams, Main)
    end
end

function y:SetVisible(v)
    local fullVisible    = v and a.BoxEnabled and (a.BoxMode == "Full" or a.BoxMode == "Both")
    local cornersVisible = v and a.BoxEnabled and (a.BoxMode == "Corners" or a.BoxMode == "Both")

    for i = 1, 8 do
        self.Corners[i].Visible         = cornersVisible
        self.CornerOutlines[i].Visible  = cornersVisible and a.OutlinesEnabled
    end
    for i = 1, 4 do 
        self.BoxLines[i].Visible = fullVisible 
    end

    self.Name.Visible          = v and a.NameEnabled
    self.Name.Outline          = a.OutlinesEnabled

    self.Tracer.Visible        = v and a.TracerEnabled
    self.TracerOutline.Visible = v and a.TracerEnabled and a.OutlinesEnabled

    self.ViewTracer.Visible    = v and a.ViewTracerEnabled

    self.Highlight.Enabled     = v and a.HighlightP

    self.Trail.Enabled         = v and a.TrailEnabled
end

function y:Update()
    local C = self.Player.Character
    if not C then return self:SetVisible(false) end

    local hrp = C:FindFirstChild("HumanoidRootPart")
    local hum = C:FindFirstChild("Humanoid")
    if not hrp or not hum or hum.Health <= 0 then return self:SetVisible(false) end

    local dist = (b.CFrame.Position - hrp.Position).Magnitude
    if dist > a.MaxDistance then return self:SetVisible(false) end

    local screenPos, onScreen, depth = j(hrp.CFrame * a.CharacterOffset)
    if not onScreen then return self:SetVisible(false) end

    local scale = 1 / (depth / 3 * math.tan(math.rad(b.FieldOfView / 2)) * 2) * 1000
    local size  = Vector2.new(scale * a.BoxStaticXFactor, scale * a.BoxStaticYFactor)

    -- Color priority logic (same as box/tracer/name)
    local espColor = a.BoxColor
    if a.BeastCheck and n(C) then
        espColor = a.BeastColor
    elseif a.TeamCheck then
        espColor = (e.TeamColor == self.Player.TeamColor) and a.AllyColor or a.EnemyColor
    end
    if a.HighlightClosestPlayer and p() == self.Player then
        espColor = Color3.new(1,1,1)
    end


    local tl = screenPos - size / 2
    local tr = tl + Vector2.new(size.X, 0)
    local bl = tl + Vector2.new(0, size.Y)
    local br = tl + size

    local corners = {tl,tr,br,bl}
    for i = 1, 4 do
        self.BoxLines[i].From = corners[i]
        self.BoxLines[i].To   = corners[(i % 4) + 1]
        self.BoxLines[i].Color = espColor
    end

    local cornerLen = math.min(size.X, size.Y) / 8
    local cornerPts = {
        {tl, tl + Vector2.new(cornerLen, 0)}, {tl, tl + Vector2.new(0, cornerLen)},
        {tr, tr + Vector2.new(-cornerLen, 0)}, {tr, tr + Vector2.new(0, cornerLen)},
        {br, br + Vector2.new(-cornerLen, 0)}, {br, br + Vector2.new(0, -cornerLen)},
        {bl, bl + Vector2.new(cornerLen, 0)}, {bl, bl + Vector2.new(0, -cornerLen)}
    }
    for i = 1, 8 do
        self.Corners[i].From = cornerPts[i][1]
        self.Corners[i].To   = cornerPts[i][2]
        self.Corners[i].Color = espColor
        self.CornerOutlines[i].From = cornerPts[i][1]
        self.CornerOutlines[i].To   = cornerPts[i][2]
    end


    self.Name.Position = Vector2.new(tl.X + size.X / 2, tl.Y - 15)
    self.Name.Text     = self.Player.Name
    self.Name.Color    = espColor
    self.Name.Font     = a.font 
    self.Name.Size     = a.TextSize 


    local bottomCenter = Vector2.new(tl.X + size.X / 2, tl.Y + size.Y)
    local screenBottom = Vector2.new(b.ViewportSize.X / 2, b.ViewportSize.Y)
    self.TracerOutline.From = screenBottom
    self.TracerOutline.To   = bottomCenter
    self.Tracer.From        = screenBottom
    self.Tracer.To          = bottomCenter
    self.Tracer.Color       = espColor

    if a.ViewTracerEnabled then
        local head = C:FindFirstChild("Head") or hrp
        if head then
            local start = head.Position
            local endPos = start + head.CFrame.LookVector * a.ViewTracerLength
            local sX, sY = b:WorldToViewportPoint(start)
            local eX, eY = b:WorldToViewportPoint(endPos)
            self.ViewTracer.From = Vector2.new(sX.X, sX.Y)
            self.ViewTracer.To   = Vector2.new(eX.X, eX.Y)
            self.ViewTracer.Color = espColor
        end
    end

    self.Highlight.FillTransparency = a.HighlightTrans
    self.Highlight.Adornee          = C
    self.Highlight.FillColor        = espColor
    self.Highlight.OutlineColor     = a.HighlightOutlineColour


    if a.TrailEnabled then
        self.Att0.Parent = hrp
        self.Att1.Parent = hrp
        self.Att0.CFrame = CFrame.new(0, a.TrailHeightOffset, 0)
        self.Att1.CFrame = CFrame.new(0, -a.TrailHeightOffset, 0)
        self.Trail.Attachment0 = self.Att0
        self.Trail.Attachment1 = self.Att1
        self.Trail.Parent      = hrp
        self.Trail.Color       = ColorSequence.new(espColor)
    end

    -- Glow Chams — now uses the same color priority
    if a.GlowChamsEnabled then
        self:UpdateGlowChams(espColor)
    else
        self:ClearGlowChams()
    end

    self:SetVisible(true)
end

function y:Destroy()
    for i = 1, 8 do
        self.Corners[i]:Remove()
        self.CornerOutlines[i]:Remove()
    end
    for i = 1, 4 do self.BoxLines[i]:Remove() end
    self.Name:Remove()
    self.Tracer:Remove()
    self.TracerOutline:Remove()
    if self.ViewTracer then self.ViewTracer:Remove() end
    self.Highlight:Destroy()
    self.Trail:Destroy()
    self.Att0:Destroy()
    self.Att1:Destroy()
    self:ClearGlowChams()
end
local function R()
    if not a.MasterSwitch then
        for _, esp in pairs(g) do esp:SetVisible(false) end
        return
    end

    for _, plr in ipairs(d:GetPlayers()) do
        if plr ~= e then
            if not g[plr] then g[plr] = y.new(plr) end
            g[plr]:Update()
        end
    end
end

